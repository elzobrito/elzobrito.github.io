---
import { getCollection, render } from 'astro:content';
import PostPage from '../../components/PostPage.astro';
export async function getStaticPaths() {
 const posts = await getCollection('posts', ({data})=>data.locale==='pt');
 return posts.map(post=>({params:{slug:post.id.split('/').pop()},props:{post}}));
}
const { post } = Astro.props; const { Content } = await render(post);
---
<PostPage post={post} Content={Content} />
